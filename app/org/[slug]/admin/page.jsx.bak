// app/org/[slug]/admin/page.jsx
"use client";

import React, { useEffect, useState } from "react";
import { createClient as createClientBrowser } from "src/utils/supabase/client"; // client-side helper

export default function AdminPage({ params }) {
  // client component receives params prop
  // keep the slug resolution simple & safe:
  const slug = params?.slug || params;

  const [globalEvents, setGlobalEvents] = useState([]);
  const [orgEvents, setOrgEvents] = useState([]);
  const [importingId, setImportingId] = useState(null);
  const [message, setMessage] = useState(null);

  const supabase = createClientBrowser();

  useEffect(() => {
    if (!slug) return;

    async function loadEvents() {
      try {
        // global events (source = 'global' or source = 'in.world' depending on schema; adjust query)
        const { data: gdata, error: gerr } = await supabase
          .from("events")
          .select("*")
          .eq("source", "global")
          .order("created_at", { ascending: false })
          .limit(100);

        if (gerr) {
          console.error("Error loading global events:", gerr);
        } else {
          setGlobalEvents(gdata || []);
        }

        // org events
        const { data: odata, error: oerr } = await supabase
          .from("events")
          .select("*")
          .eq("organization_id", slug)
          .order("created_at", { ascending: false })
          .limit(100);

        if (oerr) {
          console.error("Error loading org events:", oerr);
        } else {
          setOrgEvents(odata || []);
        }
      } catch (err) {
        console.error("Unhandled error loading events:", err);
      }
    }

    loadEvents();
  }, [slug]);

  async function importEvent(ev) {
    if (!slug) {
      setMessage({ type: "error", text: "Missing org slug" });
      return;
    }

    setImportingId(ev.id);
    setMessage(null);

    try {
      // call server route that uses the service role to insert into DB
      const res = await fetch(`/api/org/${encodeURIComponent(slug)}/import`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(ev),
      });

      const json = await res.json();

      if (!res.ok) {
        console.error("Import failed server response:", json);
        setMessage({ type: "error", text: json?.error || "Server import failed" });
      } else {
        setMessage({ type: "success", text: `Imported: ${json?.data?.name || ev.name}` });
        // Optionally append to org events list in UI:
        setOrgEvents((prev) => (json?.data ? [json.data, ...prev] : prev));
      }
    } catch (err) {
      console.error("Error calling import route:", err);
      setMessage({ type: "error", text: "Network/server error during import" });
    } finally {
      setImportingId(null);
    }
  }

  return (
    <main className="p-6">
      <h1 className="text-3xl font-bold">Org Admin — {slug}</h1>

      {message && (
        <div style={{ marginTop: 12, color: message.type === "error" ? "crimson" : "green" }}>
          {message.text}
        </div>
      )}

      <section className="mt-6">
        <h2 className="text-2xl font-semibold">Global events</h2>
        <ul className="mt-4 space-y-4">
          {globalEvents.length === 0 && <li>No global events found.</li>}
          {globalEvents.map((ev) => (
            <li key={ev.id} style={{ display: "flex", justifyContent: "space-between" }}>
              <div>
                <div style={{ fontWeight: "bold" }}>{ev.name}</div>
                {ev.event_date && <div style={{ fontSize: 12 }}>{ev.event_date}</div>}
                {ev.description && <div style={{ fontSize: 13 }}>{ev.description}</div>}
              </div>
              <div>
                <button
                  onClick={() => importEvent(ev)}
                  disabled={importingId === ev.id}
                  style={{ padding: "8px 12px", borderRadius: 4 }}
                >
                  {importingId === ev.id ? "Importing…" : "Import into org"}
                </button>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <section className="mt-10">
        <h2 className="text-2xl font-semibold">Organization events</h2>
        {orgEvents.length === 0 && <p>No organization events found.</p>}
        <ul className="mt-4 space-y-4">
          {orgEvents.map((ev) => (
            <li key={ev.id}>
              <div style={{ fontWeight: "bold" }}>{ev.name}</div>
              {ev.event_date && <div style={{ fontSize: 12 }}>{ev.event_date}</div>}
              {ev.description && <div style={{ fontSize: 13 }}>{ev.description}</div>}
            </li>
          ))}
        </ul>
      </section>
    </main>
  );
}
